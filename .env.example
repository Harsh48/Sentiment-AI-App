# Copy to .env.local for local dev. Never commit real values.

# Postgres connection string. Local: postgres://user:pass@localhost:5432/sentiment
# Cloud Run + Cloud SQL via Unix socket: postgres://USER:PASS@/DB?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sentiment

# OpenAI API key (provided by evaluator). Never commit.
OPENAI_API_KEY=

# Model (locked per spec)
OPENAI_MODEL=gpt-4o-mini

# Worker tuning
WORKER_POLL_INTERVAL_MS=1500
WORKER_CONCURRENCY=3
